<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- LAN-only app: allow cleartext HTTP to all hosts (bridge runs over local network) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
